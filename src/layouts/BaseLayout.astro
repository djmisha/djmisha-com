---
import { createHash } from 'node:crypto';
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';
import { SITE_NAME } from '../data/schema';
import type { BaseLayoutProps } from '../types';

export type Props = BaseLayoutProps;

const {
  title,
  description = '',
  bodyClass = '',
  isHome = false,
  canonicalUrl,
  ogTitle,
  ogDescription: _ogDescription,
  ogImage,
  ogUrl,
  ogType,
  twitterTitle,
  twitterDescription: _twitterDescription,
  twitterImage,
  jsonLd,
  extraHeadContent,
} = Astro.props;

// Fall back to meta description when OG/Twitter descriptions aren't explicitly set
const ogDescription = _ogDescription || description;
const twitterDescription = _twitterDescription || description;

const siteName = SITE_NAME;

// Generate a short content hash of site.css for cache busting.
// Changes automatically on every deploy where the CSS has been modified.
const cssPath = resolve('public/css/site.css');
const cssHash = createHash('md5')
  .update(readFileSync(cssPath))
  .digest('hex')
  .slice(0, 8);

/** Escape single quotes to &#039; and double quotes to &quot; for HTML attribute safety */
function esc(s?: string): string {
  if (!s) return '';
  return s
    .replace(/&/g, '&amp;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#039;');
}
---

<!doctype html>
<html lang="en">
  <head>
    {/* 1. Title */}
    <title>{title}</title>

    {/* 2. Charset, viewport, content-type */}
    <meta http-equiv="content-type" content="text/html; charset=utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, user-scalable=no"
    />

    {/* 3. Meta description */}
    {
      description && (
        <Fragment
          set:html={`<meta name="description" content="${esc(description)}" />`}
        />
      )
    }

    {/* 4. Canonical URL */}
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}

    {/* 5. Open Graph meta tags */}
    <meta property="og:site_name" content={siteName} />
    {
      ogTitle && (
        <Fragment
          set:html={`<meta property="og:title" content="${esc(ogTitle)}" />`}
        />
      )
    }
    {
      ogDescription && (
        <Fragment
          set:html={`<meta property="og:description" content="${esc(ogDescription)}" />`}
        />
      )
    }
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogUrl && <meta property="og:url" content={ogUrl} />}
    {ogType && <meta property="og:type" content={ogType} />}

    {/* 6. Twitter Card meta tags */}
    <meta name="twitter:card" content="summary_large_image" />
    {
      twitterTitle && (
        <Fragment
          set:html={`<meta name="twitter:title" content="${esc(twitterTitle)}" />`}
        />
      )
    }
    {
      twitterDescription && (
        <Fragment
          set:html={`<meta name="twitter:description" content="${esc(twitterDescription)}" />`}
        />
      )
    }
    {twitterImage && <meta name="twitter:image" content={twitterImage} />}

    {/* 7. Favicon and apple-touch-icon links */}
    <link rel="icon" href="/images/logo-djmisha-150x150.png" sizes="32x32" />
    <link rel="icon" href="/images/logo-djmisha-200x200.png" sizes="192x192" />
    <link rel="apple-touch-icon" href="/images/logo-djmisha-200x200.png" />

    {/* 8. JSON-LD schema */}
    {
      jsonLd && jsonLd.length > 0 && (
        <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
      )
    }

    {/* 8.5. Google Fonts preconnect and loading */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Jost:wght@200;300;400;500&family=Playfair+Display:ital,wght@1,400;1,500&display=swap" rel="stylesheet" />

    {/* 9. site.css (cache-busted with content hash) */}
    <link rel="stylesheet" href={`/css/site.css?v=${cssHash}`} />

    {/* 11. FancyBox CSS (always loaded - FancyBox JS is in Footer) */}
    <link rel="stylesheet" href="/css/jquery.fancybox.min.css" />

    {/* 12. noscript.css */}
    <noscript><link rel="stylesheet" href="/css/noscript.css" /></noscript>

    {/* Extra head content (page-specific) */}
    {extraHeadContent && <Fragment set:html={extraHeadContent} />}
  </head>
  <body class={bodyClass}>
    <slot />
  </body>
</html>
