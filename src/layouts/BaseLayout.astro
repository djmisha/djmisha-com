---
export interface Props {
  title: string;
  description?: string;
  bodyClass?: string;
  isHome?: boolean;
  canonicalUrl?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogUrl?: string;
  ogType?: string;
  twitterTitle?: string;
  twitterDescription?: string;
  twitterImage?: string;
  jsonLd?: object[];
  extraHeadContent?: string;
  useFancybox?: boolean;
}

const {
  title,
  description = '',
  bodyClass = '',
  isHome = false,
  canonicalUrl,
  ogTitle,
  ogDescription: _ogDescription,
  ogImage,
  ogUrl,
  ogType,
  twitterTitle,
  twitterDescription: _twitterDescription,
  twitterImage,
  jsonLd,
  extraHeadContent,
  useFancybox = false,
} = Astro.props;

// Fall back to meta description when OG/Twitter descriptions aren't explicitly set
const ogDescription = _ogDescription || description;
const twitterDescription = _twitterDescription || description;

const siteName = "San Diego DJ for Party Events Weddings DJs spinning House Music Dance EDM";

/** Escape single quotes to &#039; and double quotes to &quot; for HTML attribute safety */
function esc(s?: string): string {
  if (!s) return '';
  return s.replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/'/g, '&#039;');
}
---
<!DOCTYPE HTML>
<html lang="en">
  <head>
    {/* 1. Title */}
    <title>{title}</title>

    {/* 2. Charset, viewport, content-type */}
    <meta http-equiv="content-type" content="text/html; charset=utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=no" />

    {/* 3. Meta description */}
    {description && <Fragment set:html={`<meta name="description" content="${esc(description)}" />`} />}

    {/* 4. Canonical URL */}
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}

    {/* 5. Open Graph meta tags */}
    <meta property="og:site_name" content={siteName} />
    {ogTitle && <Fragment set:html={`<meta property="og:title" content="${esc(ogTitle)}" />`} />}
    {ogDescription && <Fragment set:html={`<meta property="og:description" content="${esc(ogDescription)}" />`} />}
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogUrl && <meta property="og:url" content={ogUrl} />}
    {ogType && <meta property="og:type" content={ogType} />}

    {/* 6. Twitter Card meta tags */}
    <meta name="twitter:card" content="summary_large_image" />
    {twitterTitle && <Fragment set:html={`<meta name="twitter:title" content="${esc(twitterTitle)}" />`} />}
    {twitterDescription && <Fragment set:html={`<meta name="twitter:description" content="${esc(twitterDescription)}" />`} />}
    {twitterImage && <meta name="twitter:image" content={twitterImage} />}

    {/* 7. Favicon and apple-touch-icon links */}
    <link rel="icon" href="/images/logo-djmisha-150x150.png" sizes="32x32" />
    <link rel="icon" href="/images/logo-djmisha-200x200.png" sizes="192x192" />
    <link rel="apple-touch-icon" href="/images/logo-djmisha-200x200.png" />

    {/* 8. JSON-LD schema */}
    {jsonLd && jsonLd.length > 0 && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    {/* 9. main.css */}
    <link rel="stylesheet" href="/css/main.css" />

    {/* 10. custom.css */}
    <link rel="stylesheet" href="/css/custom.css" />

    {/* 11. FancyBox CSS (always loaded - FancyBox JS is in Footer) */}
    <link rel="stylesheet" href="/css/jquery.fancybox.min.css" />

    {/* 12. noscript.css */}
    <noscript><link rel="stylesheet" href="/css/noscript.css" /></noscript>

    {/* 14. Ratings widget inline style */}
    <style is:inline type="text/css" media="screen">.ratings a{display:block;text-decoration:none}.ratings a:hover .total-stars{text-decoration:underline}.ratings__text{display:inline-block;line-height:15px;vertical-align:top}.ratings__stars{display:inline-block;margin-left:7px;vertical-align:top}.ratings__star{display:inline-block;vertical-align:top}.ratings__star svg{display:block;height:15px;width:15px}</style>

    {/* Extra head content (page-specific) */}
    {extraHeadContent && <Fragment set:html={extraHeadContent} />}
  </head>
  <body class={bodyClass}>
    <slot />
  </body>
</html>
