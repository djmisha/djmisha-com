---
import FullWidthLayout from '../../layouts/FullWidthLayout.astro';
import { buildJsonLd } from '../../data/schema';

const jsonLd = buildJsonLd({
  '@context': 'http://schema.org/',
  '@type': 'WebPage',
  url: 'https://djmisha.com/services/',
  headline: 'DJ Services',
  mainEntityOfPage: 'https://djmisha.com/services/',
});
---

<FullWidthLayout
  title="DJ Services"
  description="Hire DJ near you for Parties, Weddings and Corporate events, read more about DJ Services offered in San Diego and around the world. Playing edm, house, techno, club, lounge music."
  canonicalUrl="https://djmisha.com/services/"
  ogTitle="DJ Services in San Diego, Weddings, Parties, Private Events"
  ogImage="https://djmisha.com/images/logo-djmisha.png"
  ogUrl="https://djmisha.com/services/"
  ogType="website"
  twitterTitle="DJ Services in San Diego, Weddings, Parties, Private Events"
  twitterImage="https://djmisha.com/images/logo-djmisha.png"
  jsonLd={jsonLd}
>
  <p>
    Since 2001, DJ Misha has delivered unforgettable music experiences for
    weddings, corporate events, private parties, and destinations worldwide.
    From live DJ and saxophone fusion to full-service wedding entertainment,
    explore our range of services designed to make your event extraordinary.
  </p>

  <section id="primary-services">
    <h2>Our Services</h2>
    <div class="row gtr-uniform">
      <div class="col-6 col-12-medium">
        <div class="service-box service-box--dark">
          <h3 class="service-box__title">DJ &amp; Saxophone</h3>
          <p class="service-box__subtitle">Live Music &amp; DJ Fusion</p>
          <p class="service-box__description">
            Experience the thrill of a live saxophonist improvising over DJ
            Misha's dance beats, creating a one-of-a-kind fusion that keeps your
            guests on the dance floor all night. Perfect for weddings, corporate
            events, and private parties.
          </p>
          <p class="service-box__price">Starting from $4,000</p>
          <ul class="actions">
            <li>
              <a
                href="/dj-saxophone/"
                class="button"
                aria-label="Learn more about DJ and Saxophone">Learn More</a
              >
            </li>
          </ul>
        </div>
      </div>
      <div class="col-6 col-12-medium">
        <div class="service-box service-box--dark">
          <h3 class="service-box__title">Wedding DJ</h3>
          <p class="service-box__subtitle">Your Perfect Soundtrack</p>
          <p class="service-box__description">
            We work closely with you to design a personalized DJ set that tells
            your love story, from ceremony to last dance. With over 15 years of
            experience and five-star reviews, we create seamless musical
            journeys your guests will remember.
          </p>
          <p class="service-box__price">Starting from $2,500</p>
          <ul class="actions">
            <li>
              <a
                href="/services/wedding-dj-in-san-diego/"
                class="button"
                aria-label="Learn more about Wedding DJ">Learn More</a
              >
            </li>
          </ul>
        </div>
      </div>
      <div class="col-6 col-12-medium">
        <div class="service-box service-box--dark">
          <h3 class="service-box__title">Corporate Event DJ</h3>
          <p class="service-box__subtitle">Professional Entertainment</p>
          <p class="service-box__description">
            Bring polished, high-energy entertainment to your company event with
            a DJ trusted by brands like KPMG, Intel, and Banana Republic. We
            curate every set to match your crowd and vision, with optional live
            saxophone and MC services.
          </p>
          <p class="service-box__price">Starting from $2,500</p>
          <ul class="actions">
            <li>
              <a
                href="/services/corporate-event-dj-in-san-diego/"
                class="button"
                aria-label="Learn more about Corporate Event DJ">Learn More</a
              >
            </li>
          </ul>
        </div>
      </div>
      <div class="col-6 col-12-medium">
        <div class="service-box service-box--dark">
          <h3 class="service-box__title">Party DJ</h3>
          <p class="service-box__subtitle">Private Events &amp; Celebrations</p>
          <p class="service-box__description">
            Keep your guests dancing all night with a professional DJ who
            tailors every set to your musical taste and crowd. Includes a
            top-grade sound system, setup, and a collaborative music planning
            session.
          </p>
          <p class="service-box__price">Starting from $2,000</p>
          <ul class="actions">
            <li>
              <a
                href="/services/party-birthday-dj-in-san-diego/"
                class="button"
                aria-label="Learn more about Party DJ">Learn More</a
              >
            </li>
          </ul>
        </div>
      </div>
      <div class="col-6 col-12-medium">
        <div class="service-box service-box--dark">
          <h3 class="service-box__title">Destination DJ</h3>
          <p class="service-box__subtitle">Worldwide Wedding Entertainment</p>
          <p class="service-box__description">
            We bring our signature DJ and live music experience to your wedding
            anywhere in the world. From travel and equipment coordination to
            vendor planning, we handle every detail so you can focus on
            celebrating.
          </p>
          <p class="service-box__price">Starting from $5,000</p>
          <ul class="actions">
            <li>
              <a
                href="/services/destination-wedding-dj/"
                class="button"
                aria-label="Learn more about Destination DJ">Learn More</a
              >
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section id="addons" style="margin-top: 3em;">
    <h2>Additional Capabilities &amp; Add-ons</h2>
    <p style="margin-bottom: 2em;">
      These services are offered in partnership with our trusted vendors,
      ensuring the same level of quality and professionalism you expect from DJ
      Misha.
    </p>
    <div class="row gtr-uniform">
      <div class="col-6 col-12-medium">
        <div class="service-box service-box--dark">
          <h3 class="service-box__title">Lighting</h3>
          <p class="service-box__subtitle">Custom Event Ambiance</p>
          <p class="service-box__description">
            Transform your venue with professional lighting design that sets the
            perfect mood for every moment of your event. From warm uplighting
            during dinner to dynamic dance floor effects, we create an immersive
            atmosphere tailored to your vision.
          </p>
          <p class="service-box__price">Starting from $1,500</p>
          <ul class="actions">
            <li>
              <a
                href="/contact/"
                class="button"
                aria-label="Learn more about Lighting">Learn More</a
              >
            </li>
          </ul>
        </div>
      </div>
      <div class="col-6 col-12-medium">
        <div class="service-box service-box--dark">
          <h3 class="service-box__title">Portrait Lounge</h3>
          <p class="service-box__subtitle">Photo Booth Experience</p>
          <p class="service-box__description">
            Give your guests a memorable keepsake with our modern portrait
            lounge featuring professional lighting and curated backdrops. Each
            session delivers high-quality photos your guests can share instantly
            and treasure for years.
          </p>
          <p class="service-box__price">Pricing varies by package</p>
          <ul class="actions">
            <li>
              <a
                href="/contact/"
                class="button"
                aria-label="Learn more about Portrait Lounge">Learn More</a
              >
            </li>
          </ul>
        </div>
      </div>
      <div class="col-6 col-12-medium">
        <div class="service-box service-box--dark">
          <h3 class="service-box__title">Live Guitar</h3>
          <p class="service-box__subtitle">Acoustic Accompaniment</p>
          <p class="service-box__description">
            Add a live acoustic guitarist to your event for an elegant touch
            during cocktail hour, dinner, or ceremony. The blend of live strings
            with curated DJ sets creates a rich, layered soundscape your guests
            will love.
          </p>
          <p class="service-box__price">Pricing varies by package</p>
          <ul class="actions">
            <li>
              <a
                href="/contact/"
                class="button"
                aria-label="Learn more about Live Guitar">Learn More</a
              >
            </li>
          </ul>
        </div>
      </div>
      <div class="col-6 col-12-medium">
        <div class="service-box service-box--dark">
          <h3 class="service-box__title">Dance Floor LED Effects</h3>
          <p class="service-box__subtitle">Visual Dance Experience</p>
          <p class="service-box__description">
            Elevate your dance floor with stunning LED visuals that sync to the
            music and energize the crowd. Our programmable lighting effects turn
            any space into a vibrant, club-quality dance experience your guests
            won't forget.
          </p>
          <p class="service-box__price">Pricing varies by package</p>
          <ul class="actions">
            <li>
              <a
                href="/contact/"
                class="button"
                aria-label="Learn more about Dance Floor LED Effects">Learn More</a
              >
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <p style="margin-top: 3em;">
    Every event is unique, and we'd love to help you create the perfect
    experience. Whether you need a custom package or want to discuss your
    event's specific needs, <a href="/contact/">get in touch</a> for a personalized
    quote.
  </p>
</FullWidthLayout>
