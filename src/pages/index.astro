---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import Testimonial from '../components/Testimonial.astro';
import Icon from '../components/Icon.astro';
import { buildJsonLd } from '../data/schema';
import { PHONE, GOOGLE_REVIEW_URL } from '../data/config';
import { blogPosts } from '../data/blog-posts';
import reviews from '../data/reviews.json';

const jsonLd = buildJsonLd();
const reviewCount = reviews.totalReviews;
const reviewRating = reviews.totalRating;
const homeBlogPosts = blogPosts.slice(0, 4);
---

<BaseLayout
  title="San Diego DJ for Weddings, Corporate Events & Parties"
  description="San Diego DJ for hire; spinning dance and house music at corporate events, parties, weddings, birthdays and all occasions. Planning a party? Book DJ Misha."
  bodyClass="is-preload landing"
  isHome={true}
  canonicalUrl="https://djmisha.com/"
  ogTitle="San Diego DJ for Weddings, Corporate Events & Parties - DJ Misha"
  ogImage="https://djmisha.com/images/logo-djmisha.png"
  ogUrl="https://djmisha.com/"
  ogType="website"
  twitterTitle="San Diego DJ for Weddings, Corporate Events & Parties - DJ Misha"
  twitterImage="https://djmisha.com/images/logo-djmisha.png"
  jsonLd={jsonLd}
>
  <Navigation isHome={true} />

  <!-- Banner -->
  <section id="banner">
    <div class="content">
      <header>
        <h2>DJ Misha</h2>
        <strong>San Diego DJ</strong> for any occasion<br />
        Corporate Events, Parties, Weddings, Birthdays, Nightlife, Festivals <br
        />
        <br />
        <br />
        Professional, Top Rated DJ Services<br /> "He brings the party and makes you
        want to dance!"
        <br />
        <br />
        <strong>Planning a party?</strong>
        <br />
        <a href="/contact/" rel="nofollow"
          >DJ Misha would love to provide the music!</a
        >
        <br />
      </header>
      <span class="image"><img src="/images/pic01.jpg" alt="dj misha" /></span>
    </div>
    <a href="#one" class="goto-next scrolly" rel="nofollow">Next</a>
  </section>

  <!-- One -->
  <section id="one" class="spotlight style1 bottom">
    <span class="image fit main"
      ><img src="/images/pic02.jpg" alt="san diego dj" /></span
    >
    <div class="home-video"></div>
    <div class="content">
      <div class="container">
        <div class="row">
          <div class="col-4 col-12-medium">
            <header>
              <h2>San Diego DJ spinning<br />Dance &amp; House Music</h2>
              <p>"Last night a DJ saved my life!"</p>
            </header>
          </div>
          <div class="col-4 col-12-medium">
            <p>
              DJ Misha started DJ'ing in 2001, the year he fell in love with
              dance music and wanted to give people the same feeling he had
              experienced when listening and dancing to an amazing DJ set.
            </p>
          </div>
          <div class="col-4 col-12-medium">
            <p>
              DJ technology has evolved dramatically in the last decade, but the
              essence of the DJ has remained the same. The job is simple, select
              good music and blend it to create an experience.
            </p>
          </div>
        </div>
      </div>
    </div>
    <a href="#two" class="goto-next scrolly" rel="nofollow">Next</a>
  </section>

  <!-- Two -->
  <section id="two" class="spotlight style2 right">
    <span class="image fit main"
      ><img src="/images/pic03.jpg" alt="dj turntables" /></span
    >
    <div class="content">
      <header>
        <h2>Tools of the DJ</h2>
        <p>"Vinyl Records and Turntables"</p>
      </header>
      <p>
        <strong>Music Genres and Styles</strong><br />
        House Music · Tech House · Melodic House · Deep House · EDM · Nu Disco · Progressive
        · Techno · Downtempo · Lounge · Top 40 · Pop Dance · Hip-Hop · R&amp;B · 80s
        through todays Hits — curated live for your crowd<br />
        <br /><br />
        <strong>Professional DJ Equipment for Any Venue</strong><br />
        Full sound systems scaled to your event size<br />
        DJ Booth &amp; Decks · JBL Speakers &amp; Subwoofers · Wireless Microphones
        · Dance Lighting
      </p>
      <br />
      <ul class="actions">
        <li>
          <a href="/services/" class="button" rel="nofollow">Learn More</a>
        </li>
      </ul>
    </div>
    <a href="#three" class="goto-next scrolly" rel="nofollow">Next</a>
  </section>

  <!-- Three -->
  <section id="three" class="spotlight style3 left">
    <span class="image fit main bottom">
      <img src="/images/pic04.jpg" alt="dj and saxophone" />
    </span>
    <div class="content">
      <header>
        <h2>DJ and Saxophone Duo</h2>
        <p>with Jason Whitmore playing Saxophone</p>
      </header>
      <p>
        Talented saxophone player Jason Whitmore is a crowd pleaser when he
        plays along side with DJ Misha's dance beats
      </p>
      <div id="slide3">
        <br />
        <ul class="actions">
          <li>
            <a href="/dj-saxophone/" class="button">DJ &amp; Saxophone </a>
          </li>
        </ul>
      </div>
      <a href="#four" class="goto-next scrolly" rel="nofollow">Next</a>
    </div>
  </section>

  <!-- Six - Reviews & Services -->
  <section id="six" class="wrapper style1 special fade">
    <div class="container">
      <header>
        <h2>
          Top Rated DJ Services<br />
          <Icon name="star" size="0.6em" class="star-orange" />
          <Icon name="star" size="0.6em" class="star-orange" />
          <Icon name="star" size="0.6em" class="star-orange" />
          <Icon name="star" size="0.6em" class="star-orange" />
          <Icon name="star" size="0.6em" class="star-orange" />
        </h2>
        <p>
          <a
            class="ratings"
            href={GOOGLE_REVIEW_URL}
            rel="nofollow noopener"
            target="_blank"
          >
            DJ Misha is Rated {reviewRating}/5 stars based on {reviewCount} reviews
          </a>
        </p>
      </header>
      <div class="row">
        <div class="col-6 col-12-medium">
          <Testimonial
            quote="DJ Misha played at our annual holiday party and did an amazing job. He read the crowd so well and had everyone smiling, laughing and dancing - I enjoyed the ambiance he created for us. He <strong>turned our party up</strong> a notch and we plan to have him back next year!"
            author="Rececca Troydon"
            teaser="turned our party up"
          />
          <Testimonial
            quote="I can attest to the awesome party brought by DJ Misha. He sets the mood and <strong>makes you want to dance</strong>."
            author="Joanna Nieves"
            teaser="makes you want to dance"
          />
          <Testimonial
            quote="DJ Misha played at our company product launch party and was awesome! He had a great variety of music that appealed to everyone and <strong>kept the energy going</strong> throughout the event."
            author="Misty"
            teaser="music that appealed to everyone"
          />
        </div>
        <div class="col-6 col-12-medium">
          <Testimonial
            quote="We hired DJ Misha and his saxophone playing partner for our company Holiday Party in December and I have never gotten so much positive feedback from all who attended. They were the <strong>perfect combination of live music and DJ</strong> songs and kept the dance floor full the entire night! I would recommend them for any party or event."
            author="Tori, 2016"
            teaser="perfect combo of live music and DJ"
          />
          <Testimonial
            quote="He is accommodating and humble when it comes to his talents but rest assured this guy knows what he's doing and knows how to make the party!"
            author="Jason Whitmore Saxophone"
            teaser="knows how to make the party"
          />
          <Testimonial
            quote="DJ Misha was <strong>absolutely perfect for our event</strong>. The music he picked for our crowd was on point and set the tone perfectly."
            author="Lindsey Snyder"
            teaser="absolutely perfect for our event"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section id="services" class="wrapper style1 special fade">
    <div class="container">
      <h2>
        Proffesional DJ Services <span class="services-subhead"
          >for Corporate Events, Weddings, Private Parties</span>
      </h2>
      <p class="services-intro">
        Get ready to dance the night away with our expert DJ services! We offer
        an incredible selection of dance music for any occasion. Whether you're
        tying the knot and need the perfect soundtrack for your special day or
        you're hosting a corporate event or private party, DJ Misha has got you
        covered.
      </p>
      <br />
      <div class="row">
        <div class="col-4 col-12-medium">
          <div class="service-card">
            <div class="service-card-image">
              <div class="wedding-dj-video"></div>
              <img
                src="/images/dj-service-wedding.jpg"
                alt="Wedding DJ"
                style="width: 100%;"
                class="wedding-dj-image"
              />
              <h3>Wedding DJ</h3>
            </div>
            <p>
              Say "I do" to our Wedding DJ services, where we'll help you create
              the perfect atmosphere for every part of your big day. From the
              ceremony to the cocktail hour, and right through to the reception,
              we'll keep the tunes bumping and the dance floor packed.
            </p>
            <ul class="actions service-actions">
              <li>
                <a
                  href="/services/wedding-dj-in-san-diego/"
                  class="button"
                  rel="nofollow">Learn More</a
                >
              </li>
            </ul>
          </div>
        </div>
        <div class="col-4 col-12-medium">
          <div class="service-card">
            <div class="service-card-image">
              <img
                src="/images/dj-service-corporate.jpg"
                alt="Corporate DJ"
                style="width: 100%;"
              />
              <h3>Corporate DJ</h3>
            </div>
            <p>
              Take your corporate event to the next level with our Corporate DJ
              services. We'll work with any venue to ensure your event is
              unforgettable. Our professional sound equipment and music
              selection will have your guests raving about your event for years
              to come.
            </p>
            <ul class="actions service-actions">
              <li>
                <a
                  href="/services/corporate-event-dj-in-san-diego/"
                  class="button"
                  rel="nofollow">Learn More</a
                >
              </li>
            </ul>
          </div>
        </div>
        <div class="col-4 col-12-medium">
          <div class="service-card">
            <div class="service-card-image">
              <img
                src="/images/dj-service-party.jpg"
                alt="Private Party DJ"
                style="width: 100%;"
              />
              <h3>Private Party DJ</h3>
            </div>
            <p>
              Planning a private party? Look no further than DJ Misha! We
              provide top-of-the-line DJ and sound equipment services in San
              Diego and surrounding areas. We guarantee your guests will have a
              blast as we provide the musical entertainment that will keep them
              dancing all night long.
            </p>
            <ul class="actions service-actions">
              <li>
                <a
                  href="/services/party-birthday-dj-in-san-diego/"
                  class="button"
                  rel="nofollow">Learn More</a
                >
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Four - Videos & Blog -->
  <section id="four" class="wrapper style1 special fade-up">
    <div class="container">
      <header class="major">
        <h3>Watch Videos</h3>
        <div class="row uniform">
          <section class="col-3 col-12-medium">
            <a href="https://www.youtube.com/embed/pC1JDp0rNCk" data-fancybox>
              <img
                src="/images/vid4.jpg"
                alt="play video"
                style="width: 100%;"
              />
            </a>
            <p>Margarita Month Festival</p>
          </section>
          <section class="col-3 col-12-medium">
            <a href="https://www.youtube.com/embed/TJjdCK0Qq1c" data-fancybox>
              <img
                src="/images/vid1.jpg"
                alt="play video"
                style="width: 100%;"
              />
            </a>
            <p>Banana Republic Corporate Event with DJ + Saxophone</p>
          </section>
          <section class="col-3 col-12-medium">
            <a href="https://www.youtube.com/embed/lQkUsgD0Bio" data-fancybox>
              <img
                src="/images/vid2.jpg"
                alt="play video"
                style="width: 100%;"
              />
            </a>
            <p>Uncorked Wine Festival</p>
          </section>
          <section class="col-3 col-12-medium">
            <a href="https://www.youtube.com/embed/zcSpRqKdBvI" data-fancybox>
              <img
                src="/images/vid3.jpg"
                alt="play video"
                style="width: 100%;"
              />
            </a>
            <p>Pacific Magazine Festival</p>
          </section>
        </div>
      </header>

      <h3>Latest From DJ Misha's Blog</h3>
      <div class="box alt">
        <div class="row uniform">
          {
            homeBlogPosts.map((post) => (
              <section class="col-3 col-12-medium">
                <a href={`/blog/${post.slug}/`} rel="nofollow">
                  <div style="padding:0 10px;" class="image-w">
                    <img
                      width={post.imageWidth}
                      height={post.imageHeight}
                      src={post.image}
                      class="attachment-medium size-medium wp-post-image"
                      alt={post.title}
                      decoding="async"
                      loading="lazy"
                    />
                  </div>
                </a>
                <h4>
                  <a href={`/blog/${post.slug}/`} rel="bookmark">
                    {post.title}
                  </a>
                </h4>
              </section>
            ))
          }
        </div>
      </div>

      <footer class="major">
        <ul class="actions special">
          <li>
            <a href="/blog/" class="button" rel="nofollow">More from our Blog</a
            >
          </li>
        </ul>
      </footer>
    </div>
  </section>

  <!-- Five - CTA -->
  <section id="five" class="wrapper style2 special fade">
    <div class="container">
      <header>
        <h2>Exceptional events deserve the right soundtrack<br /></h2>
        <p>Let's bring your musical vision to life</p>
      </header>
      <div class="container 25%">
        <ul class="actions special">
          <li>
            <a href="/contact/" class="button special" rel="nofollow"
              >Book DJ Misha</a
            >
          </li>
        </ul>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  .services-subhead {
    display: block;
    font-size: 0.8em;
  }

  .services-intro {
    max-width: 680px;
    margin-inline: auto;
  }

  .service-card {
    text-align: left;
    background: var(--color-bg-tertiary);
    padding: 1rem;
  }

  .service-card p {
    font-size: 0.9em;
    line-height: 1.8em;
  }

  .service-card-image {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
  }

  .service-card-image::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.3);
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .service-card-image:hover::after {
    opacity: 0;
  }

  .service-card-image img {
    display: block;
  }

  .service-card-image h3 {
    position: absolute;
    margin: 0;
    text-align: center;
    z-index: 3;
  }

  .service-card-image .wedding-dj-video {
    position: relative;
    z-index: 2;
    width: 100%;
  }

  @media (min-width: 769px) {
    .service-card-image .wedding-dj-video {
      position: absolute;
      inset: 0;
    }
  }

  @media (max-width: 768px) {
    .service-card {
      margin-bottom: 2rem;
    }
  }
</style>
