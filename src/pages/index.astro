---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

const jsonLdSchema = [
  {
    "@context": "http://schema.org/",
    "@id": "https://djmisha.com",
    "@type": "Organization",
    "name": "San Diego DJ for Party Events Weddings DJs spinning House Music Dance EDM",
    "url": "https://djmisha.com",
    "logo": {
      "@type": "ImageObject",
      "url": "https://djmisha.com/images/logo-djmisha.png",
      "width": 400
    },
    "sameAs": [
      "https://www.instagram.com/djmishasd/",
      "https://www.youtube.com/@djmisha",
      "https://www.facebook.com/djmishaSandiego",
      "https://www.yelp.com/biz/dj-misha-san-diego-3",
      "https://www.gigtown.com/artists/dj-misha",
      "https://www.gigsalad.com/dj_misha_san_diego",
      "https://goo.gl/maps/2rRm8kBYePqaPbVE6",
      "https://www.zola.com/wedding-vendors/wedding-bands-djs/dj-misha"
    ],
    "contactPoint": {
      "telephone": "+1-619-786-2664",
      "contactType": "customer service"
    },
    "AggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "5",
      "reviewCount": "83"
    }
  },
  {
    "@context": "http://schema.org/",
    "@type": "WebSite",
    "url": "https://djmisha.com",
    "name": "San Diego DJ for Party Events Weddings DJs spinning House Music Dance EDM",
    "about": "DJ Misha is San Diego DJ for parties, corporate events and weddings. Playing house music, EDM, club, dance and much more. \r\n"
  },
  {
    "@context": "http://schema.org/",
    "@id": "#LocalBusiness",
    "@type": "LocalBusiness",
    "name": "San Diego DJ for Party Events Weddings DJs spinning House Music Dance EDM",
    "url": "https://djmisha.com/",
    "image": "https://djmisha.com/images/i-4LhQfht-L.jpg",
    "priceRange": "Contact For Pricing",
    "address": [
      {
        "@type": "PostalAddress",
        "streetAddress": "4640 Cass Street #9553",
        "addressLocality": "San Diego",
        "addressRegion": "CA",
        "postalCode": "92109",
        "addressCountry": "US",
        "telephone": "+1-619-786-2664"
      }
    ],
    "employees": ["DJ Misha"]
  },
  {
    "@context": "http://schema.org",
    "@type": "Person",
    "jobTitle": "DJ",
    "name": "DJ Misha",
    "telephone": "+1-619-786-2664",
    "url": "https://djmisha.com/about/",
    "image": "https://djmisha.com/images/Best-San-Diego-DJ-djmisha.com-12-300x200.jpg"
  }
];

---
<BaseLayout
  title="San Diego DJ Misha"
  description="San Diego DJ for hire; spinning dance and house music at corporate events, parties, weddings, birthdays and all occasions. Planning a party? Book DJ Misha."
  bodyClass="is-preload landing"
  isHome={true}
  canonicalUrl="https://djmisha.com/"
  ogTitle="San Diego DJ Misha"
  ogImage="https://djmisha.com/images/logo-djmisha.png"
  ogUrl="https://djmisha.com/"
  ogType="website"
  twitterTitle="San Diego DJ Misha"
  twitterImage="https://djmisha.com/images/logo-djmisha.png"
  jsonLd={jsonLdSchema}
  useFancybox={true}
>

  <Navigation isHome={true} />

  <!-- Banner -->
  <section id="banner">
    <div class="content">
      <header>
        <h2>DJ Misha</h2>
        <strong>San Diego DJ</strong> for any occasion<br>
        Corporate Events, Parties, Weddings, Birthdays, Nightlife, Festivals <br>
        <br>
        <br>
        Professional, Top Rated San Diego DJ services<br> 15+ years of experience<br> "He brings the party and makes you want to dance!" 
        <br>
        <br>
        <strong>Planning a party?</strong>
        <br>
        <a href="/contact/" rel="nofollow">DJ Misha would love to provide the music!</a> <br>
      </header>
      <span class="image"><img src="/images/pic01.jpg" alt="dj misha" /></span>
    </div>
    <a href="#one" class="goto-next scrolly" rel="nofollow">Next</a>
  </section>

  <!-- One -->
  <section id="one" class="spotlight style1 bottom">
    <span class="image fit main"><img src="/images/pic02.jpg" alt="san diego dj" /></span>
    <div class="home-video"></div>
    <div class="content">
      <div class="container">
        <div class="row">
          <div class="col-4 col-12-medium">
            <header>
              <h2>San Diego DJ spinning<br>Dance &amp; House Music</h2>
              <p>"Last night a DJ saved my life!"</p>
            </header>
          </div>
          <div class="col-4 col-12-medium">
            <p>DJ Misha started DJ'ing in 2001, the year he fell in love with dance music and wanted to give people the same feeling he had experienced when listening and dancing to an amazing DJ set.</p>
          </div>
          <div class="col-4 col-12-medium">
            <p>DJ technology has evolved dramatically in the last decade,
            but the essence of the DJ has remained the same. The job is simple, select good music and blend it to create an experience.</p>
          </div>
        </div>
      </div>
    </div>
    <a href="#two" class="goto-next scrolly" rel="nofollow">Next</a>
  </section>

  <!-- Two -->
  <section id="two" class="spotlight style2 right">
    <span class="image fit main"><img src="/images/pic03.jpg" alt="dj turntables" /></span>
    <div class="content">
      <header>
        <h2>Tools of the DJ</h2>
        <p>"Vinyl Records and Turntables"</p>
      </header>
      <p><strong>Music Genres and Styles </strong><br>
        Playing House Music EDM Electronic Dance Music Deep House Techno Electronica Nu Disco Downtempo Lounge Progressive Electro Trance Underground Pop Future Hits and much more...<br>
        <br><br>
        <strong>DJ Services for Parties, Weddings</strong><br>
        Quality Sound System for up to 500 people<br>
        DJ Booth, Turntables, JBL Speakers &amp; Subwoofer, Wireless Microphones, Dance Lighting</p>
      <br>
      <ul class="actions">
        <li><a href="/services/" class="button" rel="nofollow">Learn More</a></li>
      </ul>
    </div>
    <a href="#three" class="goto-next scrolly" rel="nofollow">Next</a>
  </section>

  <!-- Three -->
  <section id="three" class="spotlight style3 left">
    <span class="image fit main bottom">
      <img src="/images/pic04.jpg" alt="dj and saxophone" />
    </span>
    <div class="content">
      <header>
        <h2>DJ and Saxophone Duo</h2>
        <p>with Jason Whitmore playing Saxophone</p>
      </header>
      <p>Talented saxophone player Jason Whitmore is a crowd pleaser when he plays along side with DJ Misha's dance beats</p>
      <div id="slide3"> <br>
        <ul class="actions">
          <li><a href="/dj-saxophone/" class="button">DJ &amp; Saxophone  </a></li>
        </ul>
      </div>
      <a href="#four" class="goto-next scrolly" rel="nofollow">Next</a>
    </div>
  </section>

  <!-- Six - Reviews & Services -->
  <section id="six" class="wrapper style1 special fade">
    <div class="container">
      <header>
        <h2>Top Rated DJ Services<br>
          <i class="fa fa-star" aria-hidden="true"></i>
          <i class="fa fa-star" aria-hidden="true"></i>
          <i class="fa fa-star" aria-hidden="true"></i>
          <i class="fa fa-star" aria-hidden="true"></i>
          <i class="fa fa-star" aria-hidden="true"></i>
        </h2>
        <p>
          <a class="ratings" href="https://www.google.com/search?q=dj+misha&oq=dj+misha&aqs=chrome..69i57j46i175i199i512j0i10l2j69i60l2j69i61j69i65.1834j0j7&sourceid=chrome&ie=UTF-8#lrd=0x80dbffcb31404e13:0x3fae10d8742ab418,1,,," rel="nofollow noopener" target="_blank">
            DJ Misha is Rated 5/5 stars based on 83 reviews
          </a>
        </p>
      </header>
      <div class="row">
        <div class="col-6 col-12-medium">
          <div class="home-testi">
            <h3>DJ Misha played at our annual holiday party and did an amazing job.  He read the crowd so well and had everyone smiling, laughing and dancing - I enjoyed the ambiance he created for us. He <strong>turned our party up</strong> a notch and we plan to have him back next year!
            <br><br>
            <i class="fas fa-user"></i> Rececca Troydon
            </h3>
            <div class="t-short">turned our party up</div>
          </div>
          <div class="home-testi">
            <h3>I can attest to the awesome party brought by DJ Misha. He sets the mood and <strong>makes you want to dance</strong>.
            <br><br>
            <i class="fas fa-user"></i> Joanna Nieves</h3>
            <div class="t-short">makes you want to dance</div>
          </div>
          <div class="home-testi">
            <h3><br>DJ Misha played at our company product launch party and was awesome! He had a great variety of music that appealed to everyone and <strong>kept the energy going</strong> throughout the event.
            <br><br>
            <i class="fas fa-user"></i> Misty</h3>
            <div class="t-short">music that appealed to everyone</div>
          </div>
        </div>
        <div class="col-6 col-12-medium">
          <div class="home-testi">
            <h3>We hired DJ Misha and his saxophone playing partner for our company Holiday Party in December and I have never gotten so much positive feedback from all who attended. They were the <strong>perfect combination of live music and DJ</strong> songs and kept the dance floor full the entire night! I would recommend them for any party or event.
            <br><br>
            <i class="fas fa-user"></i> Tori, 2016</h3>
            <div class="t-short">perfect combo of live music and DJ</div>
          </div>
          <div class="home-testi">
            <h3>He is accommodating and humble when it comes to his talents but rest assured this guy knows what he's doing and knows how to make the party!
            <br><br>
            <i class="fas fa-user"></i> Jason Whitmore Saxophone</h3>
            <div class="t-short">knows how to make the party</div>
          </div>
          <div class="home-testi">
            <h3>DJ Misha was <strong>absolutely perfect for our event</strong>. The music he picked for our crowd was on point and set the tone perfectly.
            <br><br>
            <i class="fas fa-user"></i> Lindsey Snyder</h3>
            <div class="t-short">absolutely perfect for our event</div>
          </div>
        </div>
      </div>
      <br>
      <br>
      <br>
      <h2>DJ for Corporate Events, Weddings, Private Parties</h2>
      <p>Get ready to dance the night away with our expert DJ services! We offer an incredible selection of dance music for any occasion. Whether you're tying the knot and need the perfect soundtrack for your special day or you're hosting a corporate event or private party, DJ Misha has got you covered.</p>
      <br>
      <div class="row">
        <div class="col-4 col-12-medium">
          <div class="wedding-dj-video"></div>
          <img src="/images/dj-service-wedding.jpg" alt="Wedding DJ" style="width: 100%;" class="wedding-dj-image">
          <h3>Wedding DJ</h3>
          <p>
            Say "I do" to our Wedding DJ services, where we'll help you create the perfect atmosphere for every part of your big day. From the ceremony to the cocktail hour, and right through to the reception, we'll keep the tunes bumping and the dance floor packed.
          </p>
          <ul class="actions service-actions">
            <li>
              <a href="/services/wedding-dj-in-san-diego/" class="button" rel="nofollow">Learn More</a>
            </li>
          </ul>
        </div>
        <div class="col-4 col-12-medium">
          <img src="/images/dj-service-corporate.jpg" alt="Corporate DJ" style="width: 100%;">
          <h3>Corporate DJ</h3>
          <p>
            Take your corporate event to the next level with our Corporate DJ services. We'll work with any venue to ensure your event is unforgettable. Our professional sound equipment and music selection will have your guests raving about your event for years to come.
          </p>
          <ul class="actions service-actions">
            <li>
              <a href="/services/corporate-event-dj-in-san-diego/" class="button" rel="nofollow">Learn More</a>
            </li>
          </ul>
        </div>
        <div class="col-4 col-12-medium">
          <img src="/images/dj-service-party.jpg" alt="Private Party DJ" style="width: 100%;">
          <h3>Private Party DJ</h3>
          <p>
            Planning a private party? Look no further than DJ Misha! We provide top-of-the-line DJ and sound equipment services in San Diego and surrounding areas. We guarantee your guests will have a blast as we provide the musical entertainment that will keep them dancing all night long.
          </p>
          <ul class="actions service-actions">
            <li>
              <a href="/services/party-birthday-dj-in-san-diego/" class="button" rel="nofollow">Learn More</a>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Four - Videos & Blog -->
  <section id="four" class="wrapper style1 special fade-up">
    <div class="container">
      <header class="major">
        <h3>Watch Videos</h3>
        <div class="row uniform">
          <section class="col-3 col-12-medium">
            <a href="https://www.youtube.com/embed/pC1JDp0rNCk" data-fancybox>
              <img src="/images/vid4.jpg" alt="play video" style="width: 90%;">
            </a>
            <p>Margarita Month Grand Tasting Festival, DJ Misha is "Techno Titan" as printed in Pacific Magazine</p>
          </section>
          <section class="col-3 col-12-medium">
            <a href="https://www.youtube.com/embed/TJjdCK0Qq1c" data-fancybox>
              <img src="/images/vid1.jpg" alt="play video" style="width: 100%;">
            </a>
            <p>Banana Republic Corporate Event with DJ + Saxophone</p>
          </section>
          <section class="col-3 col-12-medium">
            <a href="https://www.youtube.com/embed/lQkUsgD0Bio" data-fancybox>
              <img src="/images/vid2.jpg" alt="play video" style="width: 100%;">
            </a>
            <p>Uncorked Wine Festival with DJ Misha</p>
          </section>
          <section class="col-3 col-12-medium">
            <a href="https://www.youtube.com/embed/zcSpRqKdBvI" data-fancybox>
              <img src="/images/vid3.jpg" alt="play video" style="width: 100%;">
            </a>
            <p>Pacific Magazine Margarita Festival with DJ Misha</p>
          </section>
        </div>
      </header>

      <h3>Latest From DJ Misha's Blog</h3>
      <div class="box alt">
        <div class="row uniform">
          <section class="col-3 col-12-medium">
            <a href="/blog/your-wedding-your-music-how-i-spin-a-dj-set-tailored-to-your-vision/" rel="nofollow">
              <style>.image-w img {width: 100%; height: auto;}</style>
              <div style="padding:0 10px;" class="image-w">
                <img width="298" height="200" src="/images/epic-DJ-set-wedding-dance-party-298x200.jpg" class="attachment-medium size-medium wp-post-image" alt="Your Wedding, Your Music: How I Spin a DJ Set Tailored to Your Vision" decoding="async" loading="lazy" />
              </div>
            </a>
            <h4><a href="/blog/your-wedding-your-music-how-i-spin-a-dj-set-tailored-to-your-vision/" rel="bookmark"> Your Wedding, Your Music: How I Spin a DJ Set Tailored to Your Vision </a></h4>
          </section>
          <section class="col-3 col-12-medium">
            <a href="/blog/crafting-the-perfect-toast-dj-tips-for-a-memorable-wedding-speech/" rel="nofollow">
              <style>.image-w img {width: 100%; height: auto;}</style>
              <div style="padding:0 10px;" class="image-w">
                <img width="296" height="200" src="/images/wedding-dj-toast-296x200.jpg" class="attachment-medium size-medium wp-post-image" alt="Crafting the Perfect Toast: DJ Tips for a Memorable Wedding Speech" decoding="async" loading="lazy" />
              </div>
            </a>
            <h4><a href="/blog/crafting-the-perfect-toast-dj-tips-for-a-memorable-wedding-speech/" rel="bookmark"> Crafting the Perfect Toast: DJ Tips for a Memorable Wedding Speech </a></h4>
          </section>
          <section class="col-3 col-12-medium">
            <a href="/blog/the-art-of-taking-requests-a-djs-perspective/" rel="nofollow">
              <style>.image-w img {width: 100%; height: auto;}</style>
              <div style="padding:0 10px;" class="image-w">
                <img width="274" height="200" src="/images/Screenshot-2024-09-14-at-6.18.37-AM-274x200.jpg" class="attachment-medium size-medium wp-post-image" alt="The Art of Taking Requests: A DJ&#8217;s Perspective" decoding="async" loading="lazy" />
              </div>
            </a>
            <h4><a href="/blog/the-art-of-taking-requests-a-djs-perspective/" rel="bookmark"> The Art of Taking Requests: A DJ&#8217;s Perspective </a></h4>
          </section>
          <section class="col-3 col-12-medium">
            <a href="/blog/a-guide-to-planning-for-your-wedding-with-dj-misha/" rel="nofollow">
              <style>.image-w img {width: 100%; height: auto;}</style>
              <div style="padding:0 10px;" class="image-w">
                <img width="300" height="200" src="/images/10-i-4lhqfht-l-300x200.jpg" class="attachment-medium size-medium wp-post-image" alt="A Guide to Planning for Your Wedding with DJ Misha" decoding="async" loading="lazy" />
              </div>
            </a>
            <h4><a href="/blog/a-guide-to-planning-for-your-wedding-with-dj-misha/" rel="bookmark"> A Guide to Planning for Your Wedding with DJ Misha </a></h4>
          </section>
        </div>
      </div>

      <footer class="major">
        <a href="/blog/" class="button" rel="nofollow">More from our Blog</a>
      </footer>
    </div>
  </section>

  <!-- Five - CTA -->
  <section id="five" class="wrapper style2 special fade">
    <div class="container">
      <header>
        <h2>Looking to hire a party or wedding DJ in San Diego?<br>
        </h2>
        <p>Text <a href="tel:+16197862664" style="color: white;">(619) 786-2664</a> with event details to receive a reply with availability</p>
      </header>
      <div class="container 25%">
        <a href="/contact/" class="button special" rel="nofollow">Hire DJ Misha</a>
      </div>
    </div>
  </section>

  <Footer />

</BaseLayout>
