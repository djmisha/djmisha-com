---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { buildJsonLd } from '../../data/schema';
import { SITE_URL } from '../../data/config';
import { blogPosts } from '../../data/blog-posts';

const jsonLd = buildJsonLd({
  '@context': 'http://schema.org/',
  '@type': 'WebPage',
  url: `${SITE_URL}/blog/`,
  headline: "DJ Misha's Blog",
  mainEntityOfPage: `${SITE_URL}/blog/`,
  about:
    'DJ tips, wedding music guides, and behind-the-scenes insights from DJ Misha. Read about event planning, song requests, and creating unforgettable celebrations.',
});
const blogDesc =
  'DJ tips, wedding music guides, and behind-the-scenes insights from DJ Misha. Read about event planning, song requests, and creating unforgettable celebrations.';
---

<BlogLayout
  title="DJ Misha's Blog"
  pageHeading="DJ Misha's Blog"
  description={blogDesc}
  canonicalUrl={`${SITE_URL}/blog/`}
  ogTitle="DJ Misha's Blog"
  ogImage={`${SITE_URL}/images/logo-djmisha.png`}
  ogUrl={`${SITE_URL}/blog/`}
  ogType="website"
  twitterTitle="DJ Misha's Blog"
  twitterImage={`${SITE_URL}/images/logo-djmisha.png`}
  jsonLd={jsonLd}
>
  {
    blogPosts.map((post, i) => (
      <section class="col-4 col-12-small">
        <a href={`/blog/${post.slug}/`} rel="bookmark" class="blog-card__link">
          <img
            class="blog-card__img"
            src={post.image}
            alt={post.title}
            width={post.imageWidth}
            height={post.imageHeight}
            loading={i === 0 ? 'eager' : 'lazy'}
          />
          <h2 class="blog-card__title">{post.title}</h2>
        </a>
      </section>
    ))
  }
</BlogLayout>
