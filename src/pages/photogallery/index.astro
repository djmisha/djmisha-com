---
import PageLayout from '../../layouts/PageLayout.astro';
---
<PageLayout title="Photogallery" description="Browse photos from DJ Misha's events including weddings, corporate events, private parties, and nightlife gigs in San Diego.">

  <p>Browse through photos from DJ Misha's events. From weddings to corporate parties, festivals to nightlife gigs, these photos capture the energy and excitement that DJ Misha brings to every event.</p>

  <div class="box alt">
    <div class="row gtr-uniform">
      <div class="col-4 col-12-medium">
        <span class="image fit"><img src="/images/pic01.jpg" alt="DJ Misha performing" /></span>
      </div>
      <div class="col-4 col-12-medium">
        <span class="image fit"><img src="/images/pic02.jpg" alt="San Diego DJ event" /></span>
      </div>
      <div class="col-4 col-12-medium">
        <span class="image fit"><img src="/images/pic03.jpg" alt="DJ turntables" /></span>
      </div>
      <div class="col-4 col-12-medium">
        <span class="image fit"><img src="/images/pic04.jpg" alt="DJ and Saxophone duo" /></span>
      </div>
      <div class="col-4 col-12-medium">
        <span class="image fit"><img src="/images/pic05.jpg" alt="DJ Misha at event" /></span>
      </div>
      <div class="col-4 col-12-medium">
        <span class="image fit"><img src="/images/pic06.jpg" alt="DJ performance" /></span>
      </div>
      <div class="col-4 col-12-medium">
        <span class="image fit"><img src="/images/pic07.jpg" alt="DJ Misha live" /></span>
      </div>
      <div class="col-4 col-12-medium">
        <span class="image fit"><img src="/images/pic08.jpg" alt="San Diego event DJ" /></span>
      </div>
    </div>
  </div>

  <ul class="actions">
    <li><a href="/contact/" class="button primary">Book DJ Misha</a></li>
  </ul>

</PageLayout>
