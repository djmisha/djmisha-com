  ) : (
    <span id="logo">
      <a href="/" title="San Diego DJ">San Diego DJ</a>
    </span>
  )}

  <nav id="nav">
    <ul class="nav-menu">
      <li><a href="/">Home</a></li>
      <li><a href="/services/">Services</a>
        <ul>
          <li><a href="/services/wedding-dj-in-san-diego/">Wedding DJ</a></li>
          <li><a href="/services/corporate-event-dj-in-san-diego/">Corporate Event DJ</a></li>
          <li><a href="/services/party-birthday-dj-in-san-diego/">Party &amp; Birthday DJ</a></li>
        </ul>
      </li>
      <li><a href="/dj-saxophone/">DJ &amp; Saxophone</a></li>
      <li><a href="/about/">About</a></li>
      <li><a href="/blog/">Blog</a></li>
