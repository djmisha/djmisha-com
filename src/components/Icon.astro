---
/**
 * Inline SVG Icon component — replaces Font Awesome.
 *
 * Usage:
 *   <Icon name="user" />
 *   <Icon name="star" size="1.2em" />
 *   <Icon name="instagram" />
 */
export interface Props {
  name:
    | 'user'
    | 'star'
    | 'instagram'
    | 'google'
    | 'yelp'
    | 'facebook'
    | 'spinner'
    | 'check'
    | 'bars'
    | 'phone'
    | 'mobile'
    | 'lightbulb';
  size?: string;
  class?: string;
}

const { name, size = '1em', class: className = '' } = Astro.props;
