# ── reCAPTCHA Enterprise ──────────────────────────────────────────────────────
SetEnv RECAPTCHA_SECRET_KEY "__RECAPTCHA_API_KEY__"
SetEnv RECAPTCHA_SITE_KEY "__RECAPTCHA_SITE_KEY__"
SetEnv RECAPTCHA_PROJECT_ID "__RECAPTCHA_PROJECT_ID__"

# ── Redirects (migrated from Netlify) ────────────────────────────────────────
RewriteEngine On
RewriteRule ^contact-dj-misha/?$ /contact/ [R=301,L]
RewriteRule ^photogallery/?$ / [R=301,L]
